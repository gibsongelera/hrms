# HRMS Docker Environment Configuration
# Copy this file to .env and update with your values

# ========================================
# Database Configuration
# ========================================
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=hrms_db
MYSQL_USER=hrms_user
MYSQL_PASSWORD=hrms_pass

# ========================================
# Jenkins Configuration
# ========================================
JENKINS_URL=http://localhost:9090
JENKINS_USER=gib
JENKINS_API_TOKEN=your-jenkins-api-token-here
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me
JENKINS_JAVA_OPTIONS=-Xmx2048m

# ========================================
# GitHub Configuration
# ========================================
GITHUB_TOKEN=your-github-personal-access-token
GIT_BRANCH=docker-push
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# Docker Registry Configuration
# ========================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# ========================================
# Application Configuration
# ========================================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080

# ========================================
# Email Configuration (Optional)
# ========================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM_ADDRESS=noreply@hrms.local

# ========================================
# Backup Configuration
# ========================================
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# ========================================
# Performance Tuning
# ========================================
DB_MAX_CONNECTIONS=100
PHP_MEMORY_LIMIT=512M
PHP_MAX_UPLOAD_SIZE=100M
